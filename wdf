8.MAX NYMBER IN PHP
<?php

function findMaxValue($numbers) {

    if (empty($numbers)) {
        return null;
    }

    $max = $numbers[0];

    foreach ($numbers as $number) {

        if ($number > $max) {
            $max = $number;
        }
    }

    return $max;
}

$sampleArray = [12, 45, 7, 99, 34];

echo "The maximum value is: " . findMaxValue($sampleArray);

?>
