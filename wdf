5. SUM OF TWO NUMBERS IN HTML
<!DOCTYPE html>
<html lang="en">

<head>
<meta charset="UTF-8">
<title>Sum of Even Numbers</title>

<style>
body{
    font-family: Arial;
    display: flex;
    justify-content: center;
    align-items: center;
    height: 100vh;
}
.container{
    border: 1px solid black;
    padding: 20px;
}
</style>

</head>

<body>

<div class="container">

<h2>Sum of Even Numbers in an Array</h2>

<script>

function sumOfEvenNumbers(numbers) {

    let sum = 0;

    for (let i = 0; i < numbers.length; i++) {

        if (numbers[i] % 2 === 0) {

            sum += numbers[i];

        }

    }

    return sum;

}

let numArray = [10, 15, 20, 25, 30, 35];

let result = sumOfEvenNumbers(numArray);

document.write("Array Elements: " + numArray + "<br>");

document.write("Sum of Even Numbers: " + result);

</script>

</div>

</body>
</html>

